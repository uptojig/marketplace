# --- Domain ---
# Apex/main domain. Subdomains <slug>.MAIN_DOMAIN auto-rewrite to /stores/<slug>.
# Anything else (a vendor's own domain) resolves via Store.customDomain.
# In dev set this to "localhost"; in prod use the public apex (e.g. "basketplace.co").
MAIN_DOMAIN="basketplace.co"

# --- Database ---
DATABASE_URL="postgresql://user:pass@localhost:5432/marketplace?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
EMAIL_SERVER=""
EMAIL_FROM=""

# Public base URL used in transactional emails, payment return_url, etc.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- AnyPay (Thailand) ---
# "mock" routes to local /mock-payment-gate; "live" hits the real AnyPay endpoint
ANYPAY_MODE="mock"
ANYPAY_API_BASE="https://api.anypay.example.com"
ANYPAY_MERCHANT_ID=""
ANYPAY_API_KEY=""
ANYPAY_SECRET=""

# --- QuickPay Payment Hub ---
QUICKPAY_SECRET=""
QUICKPAY_API_BASE="https://api.quickpay.co.th"
QUICKPAY_MERCHANT_ID=""
QUICKPAY_API_KEY=""
# IP ranges to accept QuickPay/AnyPay webhook hits from (comma-separated CIDR or IPs).
# Their production source IPs — NOT the per-shop droplet IPs.
QUICKPAY_EXTRA_WHITELIST_IPS=""
# DEPRECATED: superseded by the ShopDeployment table — see
# docs/multi-tenant-provisioning/. Kept here only so legacy lookups in
# /api/admin/domain-ips don't break during the transition.
DOMAIN_IP_REGISTRY='[]'

# --- Suppliers ---
CJ_API_BASE="https://developers.cjdropshipping.com/api2.0/v1"
CJ_EMAIL=""
CJ_API_KEY=""
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
ALIEXPRESS_ACCESS_TOKEN=""
# Optional: override gateway (default: https://api-sg.aliexpress.com/sync)
# ALIEXPRESS_API_BASE=""
# Optional: USD→THB rate for AliExpress (falls back to CJ_USD_THB or 36)
# ALIEXPRESS_USD_THB="36"

# Default supplier when seed/import doesn't specify one
DEFAULT_SUPPLIER="MOCK"

# --- Anthropic (Claude Messages API for store builder) ---
ANTHROPIC_API_KEY=""

# --- Object storage (S3-compatible, e.g. DigitalOcean Spaces) ---
# Used by /api/admin/upload for store logo / banner / category-banner
# uploads. All four of BUCKET/KEY/SECRET/ENDPOINT must be set or the
# admin upload endpoint returns 503 spaces_not_configured.
SPACES_ENDPOINT="https://sgp1.digitaloceanspaces.com"
SPACES_REGION="sgp1"
SPACES_BUCKET=""
SPACES_KEY=""
SPACES_SECRET=""

# --- Notifier ---
# Used for both platform-wide alerts (lib/notify) and provisioner alerts
# (shop-ready-for-whitelist messages, droplet unhealthy warnings).
NOTIFIER_DRIVER="console"         # console | discord | line
LINE_NOTIFY_TOKEN=""
DISCORD_WEBHOOK_URL=""

# --- Cloudflare (DNS + Email Routing) ---
# Single API token used for both:
#   - Email Routing aliases (Phase 1 identity verification)
#   - DNS records for shop droplet subdomains (multi-tenant provisioning)
# Required scopes on the platform zone:
#   Zone:Email Routing:Edit  AND  Zone:DNS:Edit
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""             # zone id of MAIN_DOMAIN (also used for email routing)

# --- Platform Email (Cloudflare Email Routing) ---
# Issued aliases like "{store-slug}@{PLATFORM_EMAIL_DOMAIN}" forwarded to the
# seller's personal email. Used as identity-verification anchor — auto-verified
# when forward target == owner's NextAuth login email (no OTP step). Requires
# the platform email subdomain to be on Cloudflare with Email Routing enabled.
EMAIL_PROVIDER="noop"             # cloudflare | noop
PLATFORM_EMAIL_DOMAIN="mail.example.com"

# =============================================================================
# Multi-tenant Provisioning (feat/multi-tenant-provisioning)
# =============================================================================
# Each approved store gets its own DigitalOcean droplet so the payment
# provider's IP whitelist requirement is satisfied (1 IP per shop, used for
# inbound + outbound). See docs/multi-tenant-provisioning/ for the runbook.
#
# Reuses (from sections above):
#   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ZONE_ID   — DNS for new shop subdomains
#   MAIN_DOMAIN                                — apex zone shop subdomains live under
#   NOTIFIER_DRIVER, DISCORD_WEBHOOK_URL,
#     LINE_NOTIFY_TOKEN                        — "ready for whitelist" alerts
#   NEXT_PUBLIC_BASE_URL                       — fallback for CONTROL_PLANE_BASE_URL

# DigitalOcean API token (scope: read+write for droplets + snapshots)
DIGITALOCEAN_TOKEN=""
# Default region + size for new shop droplets
DO_REGION="sgp1"
DO_SIZE="s-1vcpu-1gb"
# Snapshot id produced by infra/shop-droplet/build-snapshot.sh.
# Leave empty on first deploy — provisioner will fall back to a fresh
# Ubuntu install (slow, ~5 min). Build the snapshot once, then set this.
DO_SHOP_SNAPSHOT_ID=""
DO_FALLBACK_IMAGE="ubuntu-24-04-x64"
# Comma-separated DO SSH key IDs / fingerprints — injected into every droplet
DO_SSH_KEY_IDS=""

# Control-plane base URL — what shop droplets call back to for caddy-ask
# and update-agent. Must be publicly reachable from droplets.
# Defaults to NEXT_PUBLIC_BASE_URL if unset.
CONTROL_PLANE_BASE_URL=""

# Shared secret between control plane and on-droplet update agents.
# Generate via `openssl rand -hex 32`.
INTERNAL_API_SECRET=""

# Cron secret used by /api/cron/provisioner-tick + /api/cron/provisioner-health.
# Scheduler must send `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""

# Database URL the SHOP droplets connect to (typically VPC-internal managed
# Postgres). Defaults to DATABASE_URL if unset.
SHOP_DATABASE_URL=""

# Image the shop droplets pull. Override per-tag for canary rollouts.
SHOP_IMAGE="registry.digitalocean.com/marketplace/shop-app:latest"

# --- Transactional email (Resend) ---
# Used by lib/transactional-email/ for buyer order notifications
# (paid / shipped / delivered / refunded / abandoned-cart).
#
# Unset OR NODE_ENV !== "production" → emails log to console only
# (no network call). Production deploys MUST set both vars + verify
# the EMAIL_FROM domain in the Resend dashboard.
#
# Note: this is SEPARATE from the EMAIL_SERVER / EMAIL_FROM used by
# NextAuth above and from the Cloudflare Email Routing aliases below.
# The same EMAIL_FROM value is reused as the default "from" address
# for transactional sends.
RESEND_API_KEY=""

# --- Shadcn Studio (https://shadcnstudio.com) ---
# Required by the shadcn CLI when adding items from the @ss-components,
# @ss-blocks and @ss-themes registries declared in components.json. Both vars
# must be set (even for free items) — the CLI substitutes them into the
# registry URL. Get them from https://shadcnstudio.com → Dashboard → Billing.
# Local: copy them into .env.local. Vercel: already configured for prod.
#   npx shadcn add @ss-blocks/<name>     # add a Shadcn Studio block
#   npx shadcn add @ss-components/<name> # add a Shadcn Studio component
#   npx shadcn add @ss-themes/<name>     # add a Shadcn Studio theme
SHADCN_STUDIO_EMAIL=""
SHADCN_STUDIO_LICENSE_KEY=""
