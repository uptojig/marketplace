# --- Domain ---
# Apex/main domain. Subdomains <slug>.MAIN_DOMAIN auto-rewrite to /stores/<slug>.
# Anything else (a vendor's own domain) resolves via Store.customDomain.
MAIN_DOMAIN="localhost"

# --- Database ---
DATABASE_URL="postgresql://user:pass@localhost:5432/marketplace?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
EMAIL_SERVER=""
EMAIL_FROM=""

# --- AnyPay (Thailand) ---
# "mock" routes to local /mock-payment-gate; "live" hits the real AnyPay endpoint
ANYPAY_MODE="mock"
ANYPAY_API_BASE="https://api.anypay.example.com"
ANYPAY_MERCHANT_ID=""
ANYPAY_API_KEY=""
ANYPAY_SECRET=""
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Suppliers ---
CJ_API_BASE="https://developers.cjdropshipping.com/api2.0/v1"
CJ_EMAIL=""
CJ_API_KEY=""
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
ALIEXPRESS_ACCESS_TOKEN=""

# Default supplier when seed/import doesn't specify one
DEFAULT_SUPPLIER="MOCK"

# --- Notifier ---
NOTIFIER_DRIVER="console"
LINE_NOTIFY_TOKEN=""
DISCORD_WEBHOOK_URL=""
