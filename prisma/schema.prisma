// Marketplace MVP Schema
// Datasource: PostgreSQL. Switch to mysql if needed (mind the @db.* type changes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (NextAuth) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CUSTOMER
  VENDOR
  AGENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  // bcrypt hash for username/password sign-in. Optional because
  // Google OAuth + email magic-link users never set one — they
  // authenticate via the linked Account row instead.
  passwordHash  String?
  phone         String?   @unique
  // Manual phone/ID verification flag, separate from emailVerified.
  // Powers vendor onboarding gates.
  isVerified    Boolean   @default(false)
  dgaData       Json?     @map("dga_data")
  // Timestamp of the user's first paid order. Drives the
  // `newUsersOnly` coupon eligibility check — null = never paid.
  firstPurchaseAt DateTime?
  createdAt     DateTime  @default(now())

  accounts       Account[]
  sessions       Session[]
  store          Store?
  orders         Order[]
  addresses      Address[]
  couponUsages   CouponUsage[]
  paymentIntents PaymentIntent[]
  kycSessions    WizardSession[]

  // Agent referral fields
  agentId        String?         @map("agent_id")
  referredByAgent Agent?         @relation("AgentVendors", fields: [agentId], references: [id])
  agentProfile   Agent?          @relation("AgentUser")
  agentApprovals Agent[]         @relation("AgentApprover")
}

// --- Marketplace ---

enum Supplier {
  CJ
  ALIEXPRESS
  MOCK
}

model Store {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  logoUrl      String?
  // Storefront theme
  bannerUrl    String?
  tagline      String?
  primaryColor String?  @default("#2563eb")
  // Header layout — independent toggles per element so admins can mix.
  // logoPosition: "left" | "center"
  // menuPosition: "left" | "center" | "right"
  logoPosition String?  @default("left")
  menuPosition String?  @default("right")
  // Deprecated: themeId was a 4-preset system (modern/editorial/minimal/compact)
  // that bundled too many decisions. Replaced by per-element toggles above.
  // Column kept to avoid a destructive migration; safe to drop in a future cleanup.
  themeId      String?  @default("modern")
  // ── Vendor wizard (5-phase) ──
  // Niche drives template recommendations and product warehouse filtering.
  // brandVoice is one of: "casual" | "formal" | "playful".
  // templateId references the 20-template registry in lib/store/wizard-data.ts.
  // paletteId references the preset palette registry; falls back to primaryColor for legacy stores.
  niche        String?
  brandVoice   String?  @default("casual")
  // templateId is null for legacy stores (they use `landingBlocks` instead).
  // When set, it references `lib/templates/registry.ts` and the storefront
  // renders via `StoreRenderer` from `lib/templates/renderer.tsx`.
  templateId   String?
  paletteId    String?
  // ── Curated theme system (Phase 3) ──
  // Per-store section layout for the theme Homepage:
  //   { v: 1, sections: [{ id, hidden? }] }  (order = array order)
  // null = the theme's curated default order. See lib/storefront/theme-config.ts.
  themeConfig         Json?
  // Operator's INTENTIONAL accent override (hex, e.g. "#1e40af"). null = use the
  // theme's curated color. Deliberately separate from `paletteId` (a wizard-time
  // brand pick that must NOT silently repaint a curated theme — see the
  // minimop24 red->purple regression). See lib/storefront/resolve-store-theme.ts.
  themeAccentOverride String?
  // Optional secondary accent override (hex). When set together with
  // themeAccentOverride, themeAccentOverride paints --shop-primary and
  // themeAccentSecondary paints --shop-accent (instead of both being painted
  // by themeAccentOverride). Used by stores that want a two-color brand match
  // (e.g. logo with hot-pink lettering + sky-blue highlights).
  themeAccentSecondary String?
  // Custom domain (vendor brings their own); subdomain is derived from slug
  customDomain String?  @unique
  // Legal/business info shown on contact page + footer
  companyName  String?
  taxId        String?
  addressLine1 String?
  addressLine2 String?
  subdistrict  String?
  district     String?
  province     String?
  postalCode   String?
  country      String?  @default("TH")
  // ── Agent-generated landing page (เป็ด) ──
  // When `landingBlocks` is set, the storefront at /stores/<slug>
  // renders these blocks via BlockRenderer instead of the generic
  // product grid. Each store gets a UNIQUE page generated from its
  // own brief + products — never the same template twice.
  landingBlocks       Json?
  landingTitle        String?
  landingThemeVariant String?  // "minimal" | "cute"
  landingGeneratedAt  DateTime?
  // Generation lifecycle (slice 2 — for fire-and-forget agent runs)
  landingStatus       String?  // "generating" | "ready" | "failed"
  landingError        String?  // populated when status = "failed"
  landingBrief        String?  // operator-supplied prompt for last run (for "regenerate")
  landingStartedAt    DateTime?
  // Contact channels shown in storefront footer + contact page
  contactEmail  String?
  contactPhone  String?
  facebookUrl   String?
  messengerUrl  String?
  twitterUrl    String?
  instagramUrl  String?
  websiteUrl    String?
  lineId        String?
  // ── Platform-issued email (Cloudflare Email Routing) ──
  // Auto-provisioned alias on the platform's mail subdomain — used as an
  // identity-verification anchor. Verified automatically when forwardTo
  // equals the owner's NextAuth-verified login email; no OTP step.
  platformEmail              String?   @unique
  platformEmailForwardTo     String?
  platformEmailVerified      Boolean   @default(false)
  platformEmailVerifiedAt    DateTime?
  platformEmailProvisionedAt DateTime?
  // Admin approval gate — stores created via /onboarding start as
  // PENDING and aren't visible at /stores/<slug> until an ADMIN
  // approves them via /admin/stores. Existing stores are backfilled
  // to APPROVED in the migration so no live shop disappears.
  approvalStatus    StoreApprovalStatus @default(PENDING)
  approvalNote      String?             // admin's reason on reject
  approvedAt        DateTime?
  approvedById      String?

  ownerId      String   @unique
  // Vendor template parity — soft on/off without going through the
  // full StoreApprovalStatus state machine. Hides storefront from
  // browse but keeps the row + data intact.
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  owner                User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products             Product[]
  categories           Category[]
  items                OrderItem[]
  orders               Order[]
  addresses            Address[]
  identityVerification IdentityVerification?
  deployment           ShopDeployment?
  contactMessages      ContactMessage[]
  landingContent       StoreLandingContent?

  @@index([approvalStatus])
}

// ── Editable storefront content (per-store) ────────────────────────────────
// 1:1 with Store. Every field is nullable — adapters fall back to template
// defaults when a slot is empty, so legacy stores keep working without a
// backfill. Operators / owners edit these via the admin or vendor dashboard
// "Landing content" editor; chrome adapters read them at render time so no
// image URL or copy is ever hardcoded inside a component.
model StoreLandingContent {
  storeId        String @id
  store          Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // ── Hero (above-the-fold) ──
  heroHeadline      String?
  heroSubheadline   String?
  heroCtaLabel      String?
  heroCtaUrl        String?
  heroImageUrl      String?
  heroVideoUrl      String?
  heroAlignment     String? @default("center") // "left" | "center" | "right"

  // ── Announcement strip (above header) ──
  announcementMessage       String?
  announcementMessageMobile String?
  announcementLinkUrl       String?
  announcementEnabled       Boolean @default(true)

  // ── About / brand story ──
  aboutHeading   String?
  aboutBody      String? @db.Text
  aboutImageUrl  String?
  aboutVideoUrl  String?

  // ── Featured tiles (collection / category cards) ──
  // Shape: [{ imageUrl, label, href, eyebrow? }, ...]
  featuredTiles  Json?

  // ── Free-form CTA blocks the adapter may render between sections ──
  // Shape: [{ heading, body, ctaLabel, ctaUrl, imageUrl? }, ...]
  ctaBlocks      Json?

  // ── FAQ items ──
  // Shape: [{ q, a }, ...]
  faqItems       Json?

  // ── Testimonials / social proof ──
  // Shape: [{ name, role?, photoUrl?, quote, rating? }, ...]
  testimonials   Json?

  // ── Fine-grain color overrides (optional — paletteId is the primary
  // source of truth; this layers per-element tweaks on top) ──
  // Shape: { accent?, button?, link?, surfaceAlt?, headline?, body? }
  colorOverrides Json?

  // ── Free-form per-template extension bag ──
  // For one-off slots a single bespoke adapter needs (e.g. mega-store's
  // "category strip" copy) without bloating the schema for everyone.
  extras         Json?

  // ── Server-driven UI config (data-driven storefront) ──
  // When present, the storefront renders via the data-driven BlockRenderer
  // (lib/registry/block-registry) instead of the family-detector chain.
  // Shape (validated by lib/store/ui-config.ts Zod schema):
  //   {
  //     theme: { palette: string, fontPrimary: string, fontDisplay: string },
  //     pages: {
  //       home:    Array<{ type: string, id: string, data?: Record<string, unknown> }>,
  //       pdp:     string,   // single block id (e.g. "product-overview-04")
  //       catalog: string,
  //       cart:    string,
  //       checkout?: string,
  //       about?:    string
  //     }
  //   }
  // Each block id references a key in lib/registry/block-registry.tsx.
  // Null/undefined = use the legacy family-detector + bespoke-adapter chain.
  uiConfig       Json?

  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

enum StoreApprovalStatus {
  PENDING   // freshly created via /onboarding, awaiting admin review
  APPROVED  // public — visible at /stores/<slug>
  REJECTED  // admin rejected; owner can edit + resubmit
  SUSPENDED // previously approved, then taken down (TOS violation, fraud)
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  title             String
  titleTh           String?
  description       String?
  descriptionTh     String?
  priceTHB          Decimal  @db.Decimal(12, 2)
  compareAtPriceTHB Decimal? @db.Decimal(12, 2) // strikethrough "list" price for sale display
  imageUrl          String?
  galleryUrls       Json?    // string[] - additional product images
  supplier          Supplier
  externalProductId String
  externalPayload   Json?
  // Free-form category label, retained as a denormalized cache so
  // legacy callers + supplier-imported products keep working when
  // no Category row exists yet. New code should prefer categoryId.
  categoryName      String?
  // Owner-managed category. Nullable so products imported from CJ /
  // AliExpress can list under their supplier-provided categoryName
  // until the operator buckets them into a real Category.
  categoryId        String?
  hasVariants       Boolean  @default(false)
  active            Boolean  @default(true)
  // Stock tracking — stockReserved counts un-paid orders that have
  // locked inventory but not yet decremented stockTotal. Available =
  // stockTotal - stockReserved.
  stockTotal        Int      @default(0)
  stockReserved     Int      @default(0)
  // Multi-category cache (vendor-template parity). Primary
  // categorization still flows through categoryId/categoryName.
  categorySlugs     Json?
  // ── Rich supplier metadata (CJ `productWeight`, `productKeyAttribute`,
  // `productMaterials`, `videoUrl`, `hsCode`, `originCountry`) ──
  // All nullable so the migration is purely additive and legacy rows
  // continue to load. Enrich + backfill fill these from externalPayload.
  weightGrams       Int?
  originCountry     String?
  /// String[] of feature bullets (CJ `productKeyAttribute`). Rendered
  /// as a bulleted list under the PDP description tab.
  keyAttributes     Json?
  /// Record<string, string> of spec key/value pairs (CJ `productMaterials`
  /// / `productProperties`). Renders in the PDP "ข้อมูลจำเพาะ" tab so it
  /// stops being empty for rich CJ products.
  materials         Json?
  /// CJ `videoUrl` / `productVideoUrl`. Surfaced as a "ดูวิดีโอ" link
  /// under the PDP gallery — NOT auto-embedded.
  videoUrl          String?
  /// HS / customs code from CJ `hsCode` / `customsCode`. Used by future
  /// cross-border shipping setup.
  hsCode            String?
  // Per-product moderation. Defaults to APPROVED so existing flow
  // isn't disrupted; new vendor uploads can be set to PENDING via
  // a settings flag (admin can toggle "require product moderation"
  // on/off per-store later — for now everything ships at APPROVED).
  moderationStatus  ProductModerationStatus @default(APPROVED)
  moderationNote    String?
  moderatedAt       DateTime?
  moderatedById     String?
  createdAt         DateTime @default(now())

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  variants ProductVariant[]

  @@index([storeId, active])
  @@index([supplier, externalProductId])
  @@index([moderationStatus])
  @@index([categoryId])
}

/// Vendor-defined product grouping with a slug (used in storefront URLs)
/// and an optional banner image. A product can be in at most one
/// Category — Phase 1 keeps the model simple; multi-category /
/// hierarchical trees are out of scope.
///
/// Slugs are unique per store (so two different stores can both have
/// a "shoes" category) — enforced via @@unique([storeId, slug]).
model Category {
  id          String   @id @default(cuid())
  storeId     String
  // Display name shown in nav + on the category page header
  name        String
  // URL slug — appears in /stores/<store>/category/<slug>. Lowercase
  // alphanumerics + hyphens. Unique within the store.
  slug        String
  // Optional one-paragraph blurb under the banner. Plain text.
  description String?
  // Hero/banner image rendered at the top of the category page.
  // Same DigitalOcean Spaces URL convention as Store.bannerUrl.
  bannerUrl   String?
  // Manual ordering for nav menus. Lower = earlier. Defaults to 0
  // and ties broken by createdAt (stable, intuitive).
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, slug])
  @@index([storeId, sortOrder])
}

enum ProductModerationStatus {
  PENDING   // listed by vendor, waiting for admin review
  APPROVED  // visible to customers
  REJECTED  // hidden, vendor sees rejection reason
}

/// Append-only log of admin actions. Every approve/reject/role-change/
/// destructive operation should write a row here. Used by /admin/audit-log
/// to answer "who did what when". Never delete or update existing rows.
model AuditLog {
  id           String   @id @default(cuid())
  // The admin who performed the action.
  actorId      String
  actorEmail   String   // denormalised so log survives if user is deleted
  actorRole    Role
  // What happened — short stable verb. Examples:
  //   "store.approve" "store.reject" "store.suspend"
  //   "product.approve" "product.reject"
  //   "user.role_change" "user.delete" "user.create"
  //   "landing.regenerate"
  action       String
  // Resource targeted. Optional because some actions (e.g. login) are
  // actor-only.
  targetType   String?  // "Store" | "Product" | "User" | "Order" | …
  targetId     String?
  // Free-form payload — `before` / `after` snapshot, reason note,
  // request body fingerprint, etc.
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  externalVariantId String
  sku               String?
  attributes        Json     // { "Size": "M", "Color": "Black" }
  /// Split-out variant labels so the PDP picker can render Color +
  /// Size + Material as separate UI rows. Populated alongside
  /// `attributes` (which is kept for back-compat with existing rows
  /// + callers that expect the flat blob).
  colorLabel        String?
  sizeLabel         String?
  materialLabel    String?
  priceTHB          Decimal  @db.Decimal(12, 2)
  imageUrl          String?
  // Legacy single-counter inventory. Kept for back-compat with
  // existing reads; new code should use stockTotal/stockReserved.
  inventory         Int?
  stockTotal        Int      @default(0)
  stockReserved     Int      @default(0)
  createdAt         DateTime @default(now())

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  @@unique([productId, externalVariantId])
  @@index([productId])
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  // Phase 1C: per-store address book. A buyer's saved addresses at
  // store A are scoped (userId, storeId)-tuple; they cannot see or
  // mutate them from store B. Aligns with Q1=A architecture decision
  // (each store owns its own customers + addresses, Shopify-style).
  storeId       String
  recipientName String
  phone         String
  line1         String
  line2         String?
  subdistrict   String?
  district      String?
  province      String
  postalCode    String
  country       String  @default("TH")
  // User-supplied tag ("home" | "office" | etc.) for picker UX.
  label         String?
  // Exactly one address per (user, store) tuple should have isDefault=true;
  // the checkout default-picker reads this. App-layer invariant, not DB.
  isDefault     Boolean @default(false)
  createdAt     DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Composite index — every read now filters by (userId, storeId).
  @@index([userId, storeId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SUPPLIER_PLACED
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  // Customer-initiated return after delivery — counted separately
  // from CANCELLED so finance reports can split refund cohorts.
  RETURNED
}

// Customer-selected method on the checkout payment step.
// Stored on Order + PaymentIntent so refunds can route correctly.
enum PaymentMethod {
  PROMPTPAY
  CARD
  WALLET
  BNPL
  COD
}

model Order {
  id                  String      @id @default(cuid())
  // User-facing reference (e.g. ORD-1746984000-XKZ4). Distinct from
  // the cuid id so we can show a short, copy-friendly code on the
  // success page + emails. Nullable so old pre-vendor-merge orders
  // still satisfy the constraint; new orders always set it.
  orderRef            String?     @unique
  userId              String
  // Promoting storeId off OrderItem onto Order itself: one order =
  // one store (multi-store cart splits into multiple Orders sharing
  // a cartId). Nullable for legacy rows pre-merge.
  storeId             String?
  // Multi-store cart split marker — multiple Orders share a cartId
  // and a paymentIntentId so /order-success can group them.
  cartId              String?
  paymentIntentId     String?
  status              OrderStatus @default(PENDING_PAYMENT)
  subtotalTHB         Decimal     @db.Decimal(12, 2)
  shippingTHB         Decimal     @db.Decimal(12, 2) @default(0)
  discountTHB         Decimal     @db.Decimal(12, 2) @default(0)
  totalTHB            Decimal     @db.Decimal(12, 2)
  // Snapshot copy of the shipping address taken at order placement
  // so the order survives the user editing/deleting their address.
  shippingAddressJson Json
  paymentMethod       PaymentMethod?
  // Carrier name + tracking — populated by seller fulfillment flow.
  shippingCarrier     String?
  trackingNumber      String?
  estimatedDelivery   DateTime?
  noteToStore         String?
  paidAt              DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  store          Store?         @relation(fields: [storeId], references: [id])
  paymentIntent  PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
  items          OrderItem[]
  payment        Payment?
  appliedCoupons OrderCoupon[]
  couponUsages   CouponUsage[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([storeId, createdAt])
  @@index([cartId])
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  productId           String
  variantId           String?
  storeId             String
  qty                 Int
  unitPriceTHB        Decimal   @db.Decimal(12, 2)
  supplier            Supplier
  externalOrderId     String?
  externalTrackingNo  String?
  supplierStatus      String?
  supplierLastSyncAt  DateTime?
  // Denormalized product snapshot — survives Product deletion so
  // the customer's order history stays renderable.
  title               String?
  thumbnailUrl        String?
  variantName         String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  store   Store           @relation(fields: [storeId], references: [id])

  @@index([orderId])
  @@index([storeId])
}

enum PaymentProvider {
  ANYPAY
  MOCK
}

// Legacy 3-state for the original Payment model. PaymentIntent uses
// the richer PaymentIntentStatus below.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

// Mirrors Anypay's intent lifecycle. Reused by /api/anypay/webhook
// and the checkout/processing polling page.
enum PaymentIntentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

// =====================================================================
// PaymentIntent — our side of an Anypay (or other provider) intent.
// One per cart-checkout (idempotency key = cartId until expired).
// Multiple Orders (multi-store split) point to a single PaymentIntent.
// =====================================================================
model PaymentIntent {
  id              String              @id // Anypay intent ID
  cartId          String
  userId          String
  amountTHB       Decimal             @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  status          PaymentIntentStatus @default(PENDING)
  metadata        Json                @default("{}")
  qrCode          String?
  redirectUrl     String?
  expiresAt       DateTime?
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([cartId])
  @@index([userId, createdAt])
}

// =====================================================================
// Coupons — platform/store/product/category-scoped discount system.
// Discount + scope shapes mirror Drizzle vendor schema verbatim so the
// validate/calculator code can be ported with zero adaptation.
// =====================================================================
model Coupon {
  id                     String         @id @default(cuid())
  code                   String         @unique
  // { type: 'platform' | 'store' | 'product' | 'category',
  //   storeId?, productIds?, categorySlugs? }
  scope                  Json
  // { kind: 'percent' | 'fixed' | 'free_shipping',
  //   percent?, amount?, maxDiscount? }
  discount               Json
  minSpendTHB            Decimal?       @db.Decimal(12, 2)
  validFrom              DateTime?
  validTo                DateTime
  newUsersOnly           Boolean        @default(false)
  requiredPaymentMethod  PaymentMethod?
  maxUsesTotal           Int?
  maxUsesPerUser         Int?
  title                  String
  description            String?
  issuer                 String
  // Optional Tailwind/brand token controlling the coupon card styling.
  colorScheme            String?
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())

  usages       CouponUsage[]
  orderCoupons OrderCoupon[]

  @@index([code, isActive])
}

// =====================================================================
// CouponUsage — append-only record of each successful coupon redemption.
// Powers maxUsesTotal + maxUsesPerUser server-side enforcement.
// =====================================================================
model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  usedAt    DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([userId, couponId])
}

// =====================================================================
// OrderCoupon — join row capturing which coupons were applied to which
// order, the slot they filled (platform/store/shipping), and the
// resolved discount amount snapshot. Composite PK (orderId, couponId).
// =====================================================================
model OrderCoupon {
  orderId  String
  couponId String
  code     String
  slot     String // 'platform' | 'store' | 'shipping'
  amountTHB Decimal @db.Decimal(12, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id])

  @@id([orderId, couponId])
  @@index([couponId])
}

model Payment {
  id                   String          @id @default(cuid())
  orderId              String          @unique
  provider             PaymentProvider
  status               PaymentStatus   @default(PENDING)
  anypayTransactionId  String?         @unique
  amountTHB            Decimal         @db.Decimal(12, 2)
  paidAt               DateTime?
  rawCreateResponse    Json?
  rawWebhookPayload    Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum WebhookSource {
  ANYPAY
  CJ
  ALIEXPRESS
}

model WebhookLog {
  id              String        @id @default(cuid())
  source          WebhookSource
  endpoint        String
  headersJson     Json
  bodyJson        Json
  signatureValid  Boolean       @default(false)
  processed       Boolean       @default(false)
  processingError String?
  receivedAt      DateTime      @default(now())

  @@index([source, receivedAt])
}

// Identity verification record per store. Phase 1 covers email-based
// verification (status = EMAIL_VERIFIED when the platform email forwards to
// the owner's NextAuth-verified login email). KYC fields are placeholders
// for Phase 2 (ID upload + business doc + admin review).
enum IdentityVerificationStatus {
  PENDING
  EMAIL_VERIFIED
  KYC_VERIFIED
  REJECTED
}

model IdentityVerification {
  id              String                     @id @default(cuid())
  storeId         String                     @unique
  status          IdentityVerificationStatus @default(PENDING)
  emailVerifiedAt DateTime?
  // Phase 2 (KYC) — unused in Phase 1
  kycSubmittedAt  DateTime?
  kycReviewedAt   DateTime?
  kycEvidence     Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Multi-tenant provisioning (DigitalOcean droplet per shop)
// ============================================================================
// Each approved store gets its own droplet so the payment provider's IP
// whitelist requirement is satisfied: a single droplet has exactly one
// public IP, used for both inbound (storefront) and outbound (PG API).
//
// Lifecycle:
//   PENDING → CREATING_DROPLET → CONFIGURING_DNS → DEPLOYING_APP →
//   READY_FOR_WHITELIST → WHITELIST_REQUESTED → ACTIVE
// Failure surfaces via `lastError` + status FAILED at whichever stage broke.
// All transitions are idempotent — retrying any stage is safe.

enum ShopDeploymentStatus {
  PENDING              // queued, no droplet created yet
  CREATING_DROPLET     // DO API call sent, waiting for droplet to become active
  CONFIGURING_DNS      // droplet has IP, writing CF DNS records
  DEPLOYING_APP        // cloud-init / docker pull in progress
  READY_FOR_WHITELIST  // health check passed, awaiting PG whitelist
  WHITELIST_REQUESTED  // admin notified PG, waiting for confirmation
  ACTIVE               // fully operational, payments enabled
  SUSPENDED            // disabled by admin (TOS, non-payment) — droplet kept
  FAILED               // stuck — see lastError + provisioning jobs
  ARCHIVED             // droplet destroyed, IP released
}

model ShopDeployment {
  id        String               @id @default(cuid())
  storeId   String               @unique
  status    ShopDeploymentStatus @default(PENDING)

  // DigitalOcean droplet identity (populated once created)
  doDropletId        BigInt?
  doRegion           String?  // e.g. "sgp1"
  doSize             String?  // e.g. "s-1vcpu-1gb"
  doImageSnapshotId  String?  // snapshot used to create this droplet

  // Networking — these are the IPs the PG provider whitelists
  publicIpv4         String?  @unique
  publicIpv6         String?
  privateIpv4        String?  // for VPC backbone to control plane + managed DB

  // Cloudflare DNS record IDs (so we can update/delete cleanly on rename/destroy)
  cfRecordIdSubdomain String?  // {slug}.platform.com A record
  cfRecordIdApex      String?  // myshop.com A record (if custom domain)
  cfRecordIdWww       String?  // www.myshop.com A record (if custom domain)

  // Custom domain verification — flips true once DNS lookup matches publicIpv4.
  // Caddy's on-demand TLS `ask` endpoint refuses to issue a cert until verified.
  customDomainVerified   Boolean   @default(false)
  customDomainVerifiedAt DateTime?
  customDomainLastChecked DateTime?

  // Payment provider whitelist (manual workflow — PG has no API)
  paymentWhitelistStatus       PaymentWhitelistStatus @default(NOT_REQUESTED)
  paymentWhitelistRequestedAt  DateTime?
  paymentWhitelistConfirmedAt  DateTime?
  paymentWhitelistConfirmedBy  String?  // admin user id
  paymentWhitelistNote         String?

  // Health check + heartbeat — populated by control plane uptime poller.
  // healthyAt = last 200 from /health; missedHealthChecks increments per fail.
  healthyAt              DateTime?
  missedHealthChecks     Int       @default(0)

  // Deployment metadata — version of the snapshot the droplet was built from
  // and the version currently running (set by the on-droplet update agent).
  snapshotVersion        String?
  runningVersion         String?

  // Append-only error log — most recent failure surface for admin UI
  lastError              String?
  lastErrorAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  jobs  ProvisioningJob[]

  @@index([status])
  @@index([paymentWhitelistStatus])
}

enum PaymentWhitelistStatus {
  NOT_REQUESTED  // droplet not yet ready
  REQUESTED      // admin has contacted PG, awaiting confirmation
  CONFIRMED      // PG confirmed IP is whitelisted → payments enabled
  REJECTED       // PG refused (e.g. KYC failure) — store cannot use payments
}

// Provisioning job — every state transition (and retry attempt) becomes a row.
// Acts as both a queue (status=QUEUED rows polled by the worker) and an audit
// log so admin can see "stage X took 47s, stage Y failed twice then succeeded".

enum ProvisioningJobType {
  CREATE_DROPLET
  WAIT_FOR_DROPLET_ACTIVE
  CONFIGURE_DNS
  WAIT_FOR_APP_READY
  REQUEST_PAYMENT_WHITELIST
  HEALTH_CHECK
  DEPLOY_UPDATE       // push new snapshot/image version
  DESTROY_DROPLET     // cleanup on shop deletion
  ROTATE_IP           // for IP change (rare — usually means re-whitelist with PG)
}

enum ProvisioningJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model ProvisioningJob {
  id           String                @id @default(cuid())
  deploymentId String
  type         ProvisioningJobType
  status       ProvisioningJobStatus @default(QUEUED)
  attempt      Int                   @default(1)
  maxAttempts  Int                   @default(5)

  // Inputs/outputs persisted as JSON so we don't need a schema bump for every
  // new job type. Schema layer (lib/provisioner/jobs/*) validates at runtime.
  inputJson    Json?
  outputJson   Json?
  errorMessage String?
  errorJson    Json?

  // Visibility timeout pattern — only one worker picks up at a time
  scheduledFor DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  // After a SUCCEEDED job, follow-up job ID for traceability in the chain
  nextJobId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deployment ShopDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, type])
  @@index([status, scheduledFor])
  @@index([type, status])
}

// Persisted submissions from the public contact form at
// /stores/<slug>/contact. The PR #56 flow originally only emailed the
// store's contactEmail via Resend — this row is the new source of
// truth so vendors can find messages even when email delivery is
// flaky or contactEmail isn't set.
//
// readAt/readById track whether the vendor has acknowledged the
// message (null = unread). readById matters in the multi-vendor case
// where multiple operators share an inbox via the dashboard picker —
// it audits WHO marked the row read, not just when.
model ContactMessage {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  email       String?
  phone       String?
  message     String    @db.Text
  // Null = unread; populated = read at this timestamp.
  readAt      DateTime?
  // Audit who marked it read (for the multi-vendor case).
  readById    String?
  // Reply audit. Set together by lib/admin/contact-messages.ts
  // replyToMessage when the vendor sends an email reply via Resend.
  // The DB row is the source of truth — we persist BEFORE sendEmail
  // so a Resend failure still surfaces in the inbox transcript and
  // the vendor can retry.
  repliedAt   DateTime?
  repliedById String?
  // Snapshot of the reply body the vendor sent. Lets the inbox
  // detail page render a read-only transcript without round-tripping
  // to Resend, and keeps an audit trail of what was sent.
  replyBody   String?   @db.Text
  createdAt   DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([storeId, readAt])
}

// ============================================================================
// Upload-based KYC wizard
// ============================================================================
// Evidence-first vendor onboarding flow. DGA remains a vendor-controlled browser
// step; the server only receives uploads, runs OCR/matching, and writes audit
// records for every transition.

model WizardSession {
  id             String    @id @default(uuid()) @db.Uuid
  state          String    @default("INIT")
  userId         String?   @map("user_id")
  citizenId      String?   @map("citizen_id") @db.VarChar(13)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime  @map("expires_at")
  terminalAt     DateTime? @map("terminal_at")
  finalDecision  String?   @map("final_decision")
  pwContextId    String?   @map("pw_context_id")
  metadata       Json      @default("{}")

  user                User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  evidence            WizardEvidence[]
  ocrResults          WizardOcrResult[]
  matchResults        WizardMatchResult[]
  auditLogs           WizardAuditLog[]
  costLogs            WizardCostLog[]
  dgaFields           WizardDgaField[]
  outlookCredentials  WizardOutlookCredential[] @relation("WizardOutlookLease")

  // Agent referral fields
  agentId             String?                   @map("agent_id")
  agent               Agent?                    @relation(fields: [agentId], references: [id])

  @@index([state, expiresAt])
  @@index([citizenId])
  @@index([userId])
  @@index([agentId])
  @@map("wizard_sessions")
}

enum AgentStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

model Agent {
  id           String      @id @default(cuid())
  userId       String      @unique @map("user_id")
  linkCode     String      @unique @map("link_code") @db.VarChar(20)
  displayName  String      @map("display_name")
  status       AgentStatus @default(PENDING_APPROVAL)
  phone        String?
  lineId       String?     @map("line_id")
  note         String?     // Admin notes
  approvedAt   DateTime?   @map("approved_at")
  approvedById String?     @map("approved_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user         User            @relation("AgentUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy   User?           @relation("AgentApprover", fields: [approvedById], references: [id])
  vendors      User[]          @relation("AgentVendors")
  sessions     WizardSession[]

  @@map("agents")
}

model WizardEvidence {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  step        String
  storageKey  String   @map("storage_key")
  sha256      String   @db.Char(64)
  bytes       Int
  mime        String
  width       Int?
  height      Int?
  source      String
  capturedAt  DateTime @default(now()) @map("captured_at")

  session     WizardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ocrResults  WizardOcrResult[]
  dgaFields   WizardDgaField[]

  @@index([sessionId, capturedAt])
  @@index([step])
  @@map("evidence")
}

// Accumulating label→value checklist for S1 v2 (incremental multi-image DGA
// capture). Each row = one OCR'd field from one screenshot. UPSERT on
// (sessionId, fieldKey) implements last-write-wins so user can override a
// stale value by re-uploading a better screenshot.
//
// On finalize, the route reads all rows for the session, builds the canonical
// Identity, and writes a single `dga` provider row to wizard_ocr_results so
// downstream S2/S3/S4 cross-match lookups stay unchanged.
//
// Cascade on evidence deletion: removing an image deletes only the fields
// contributed by that evidenceId — other images' contributions survive.
model WizardDgaField {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  fieldKey    String   @map("field_key")
  value       String
  evidenceId  String   @map("evidence_id") @db.Uuid
  confidence  Decimal? @db.Decimal(4, 3)
  // false = value was captured but fails Level-1 structural sanity check
  // (UI surfaces a ⚠️ warning; does NOT block finalize).
  shapeOk     Boolean  @default(true) @map("shape_ok")
  warning     String?  // human-readable Thai warning when shapeOk = false
  // S1_DGA_REVIEW provenance — when the vendor edits a value in the
  // review step, `originalValue` captures the FIRST OCR-extracted form
  // (one-shot, never overwritten on subsequent edits) and `editedByUser`
  // flips to true. Cross-match continues to use `value` (post-edit).
  originalValue String?   @map("original_value")
  editedByUser  Boolean   @default(false) @map("edited_by_user")
  editedAt      DateTime? @map("edited_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  session  WizardSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evidence WizardEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([sessionId, fieldKey])
  @@index([sessionId])
  @@index([evidenceId])
  @@map("dga_fields")
}

model WizardOcrResult {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  evidenceId   String   @map("evidence_id") @db.Uuid
  provider     String
  rawResponse  Json     @map("raw_response")
  extracted    Json
  confidence   Decimal? @db.Decimal(4, 3)
  createdAt    DateTime @default(now()) @map("created_at")

  session   WizardSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evidence  WizardEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([sessionId, provider])
  @@index([evidenceId])
  @@map("ocr_results")
}

model WizardMatchResult {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  matchType    String   @map("match_type")
  leftSource   String   @map("left_source")
  rightSource  String   @map("right_source")
  leftValue    String?  @map("left_value")
  rightValue   String?  @map("right_value")
  score        Decimal? @db.Decimal(6, 3)
  threshold    Decimal? @db.Decimal(6, 3)
  matched      Boolean
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at")

  session WizardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, matchType])
  @@index([matched])
  @@map("match_results")
}

model WizardAuditLog {
  id          BigInt   @id @default(autoincrement())
  sessionId   String?  @map("session_id") @db.Uuid
  ts          DateTime @default(now())
  actor       String
  event       String
  fromState   String?  @map("from_state")
  toState     String?  @map("to_state")
  payload     Json     @default("{}")

  session WizardSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId, ts])
  @@index([event, ts])
  @@map("audit_log")
}

model WizardCostLog {
  id           BigInt   @id @default(autoincrement())
  sessionId    String?  @map("session_id") @db.Uuid
  ts           DateTime @default(now())
  provider     String
  endpoint     String
  units        Decimal  @db.Decimal(8, 4)
  unitType     String   @map("unit_type")
  unitCostThb  Decimal  @map("unit_cost_thb") @db.Decimal(8, 4)
  costThb      Decimal  @map("cost_thb") @db.Decimal(10, 4)
  durationMs   Int      @map("duration_ms")
  httpStatus   Int?     @map("http_status")

  session WizardSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId, ts])
  @@index([provider, endpoint])
  @@map("cost_log")
}

model WizardOutlookCredential {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  passwordEncrypted  String    @map("password_encrypted")
  status             String    @default("available")
  leasedTo           String?   @map("leased_to") @db.Uuid
  leasedAt           DateTime? @map("leased_at")
  usedAt             DateTime? @map("used_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  session WizardSession? @relation("WizardOutlookLease", fields: [leasedTo], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([leasedTo])
  @@map("outlook_pool")
}
