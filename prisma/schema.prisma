// Marketplace MVP Schema
// Datasource: PostgreSQL. Switch to mysql if needed (mind the @db.* type changes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// --- Auth (NextAuth) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  store     Store?
  orders    Order[]
  addresses Address[]
}

// --- Marketplace ---

enum Supplier {
  CJ
  ALIEXPRESS
  MOCK
}

model Store {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  logoUrl      String?
  // Storefront theme
  bannerUrl    String?
  tagline      String?
  primaryColor String?  @default("#2563eb")
  // Header layout — independent toggles per element so admins can mix.
  // logoPosition: "left" | "center"
  // menuPosition: "left" | "center" | "right"
  logoPosition String?  @default("left")
  menuPosition String?  @default("right")
  // Deprecated: themeId was a 4-preset system (modern/editorial/minimal/compact)
  // that bundled too many decisions. Replaced by per-element toggles above.
  // Column kept to avoid a destructive migration; safe to drop in a future cleanup.
  themeId      String?  @default("modern")
  // Custom domain (vendor brings their own); subdomain is derived from slug
  customDomain String?  @unique
  // Legal/business info shown on contact page + footer
  companyName  String?
  taxId        String?
  addressLine1 String?
  addressLine2 String?
  subdistrict  String?
  district     String?
  province     String?
  postalCode   String?
  country      String?  @default("TH")
  // Contact channels shown in storefront footer + contact page
  contactEmail  String?
  contactPhone  String?
  facebookUrl   String?
  messengerUrl  String?
  twitterUrl    String?
  instagramUrl  String?
  websiteUrl    String?
  lineId        String?
  ownerId      String   @unique
  createdAt    DateTime @default(now())

  owner    User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]
  items    OrderItem[]
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  title             String
  titleTh           String?
  description       String?
  descriptionTh     String?
  priceTHB          Decimal  @db.Decimal(12, 2)
  compareAtPriceTHB Decimal? @db.Decimal(12, 2) // strikethrough "list" price for sale display
  imageUrl          String?
  galleryUrls       Json?    // string[] - additional product images
  supplier          Supplier
  externalProductId String
  externalPayload   Json?
  categoryName      String?
  hasVariants       Boolean  @default(false)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  variants ProductVariant[]

  @@index([storeId, active])
  @@index([supplier, externalProductId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  externalVariantId String
  sku               String?
  attributes        Json     // { "Size": "M", "Color": "Black" }
  priceTHB          Decimal  @db.Decimal(12, 2)
  imageUrl          String?
  inventory         Int?
  createdAt         DateTime @default(now())

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  @@unique([productId, externalVariantId])
  @@index([productId])
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  recipientName String
  phone         String
  line1         String
  line2         String?
  subdistrict   String?
  district      String?
  province      String
  postalCode    String
  country       String  @default("TH")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SUPPLIER_PLACED
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

model Order {
  id                  String      @id @default(cuid())
  userId              String
  status              OrderStatus @default(PENDING_PAYMENT)
  subtotalTHB         Decimal     @db.Decimal(12, 2)
  shippingTHB         Decimal     @db.Decimal(12, 2) @default(0)
  totalTHB            Decimal     @db.Decimal(12, 2)
  shippingAddressJson Json
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   OrderItem[]
  payment Payment?

  @@index([userId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  productId           String
  variantId           String?
  storeId             String
  qty                 Int
  unitPriceTHB        Decimal   @db.Decimal(12, 2)
  supplier            Supplier
  externalOrderId     String?
  externalTrackingNo  String?
  supplierStatus      String?
  supplierLastSyncAt  DateTime?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  store   Store           @relation(fields: [storeId], references: [id])

  @@index([orderId])
  @@index([storeId])
}

enum PaymentProvider {
  ANYPAY
  MOCK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Payment {
  id                   String          @id @default(cuid())
  orderId              String          @unique
  provider             PaymentProvider
  status               PaymentStatus   @default(PENDING)
  anypayTransactionId  String?         @unique
  amountTHB            Decimal         @db.Decimal(12, 2)
  paidAt               DateTime?
  rawCreateResponse    Json?
  rawWebhookPayload    Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum WebhookSource {
  ANYPAY
  CJ
  ALIEXPRESS
}

model WebhookLog {
  id              String        @id @default(cuid())
  source          WebhookSource
  endpoint        String
  headersJson     Json
  bodyJson        Json
  signatureValid  Boolean       @default(false)
  processed       Boolean       @default(false)
  processingError String?
  receivedAt      DateTime      @default(now())

  @@index([source, receivedAt])
}
